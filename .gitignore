# Ignore everything by default
*

# Todo tracking files (task breakdowns, plans, notes, changelogs — treated as specs/docs)
!.claude/
!.claude/todo-pr-*.md

# Track these directories
!.gitignore
!CLAUDE.md
!Makefile
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!settings.json
!statusline.sh
!ways.json
!.claude-upstream

# GitHub community health files
!.github/
!.github/FUNDING.yml
!.github/pull_request_template.md
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/*.md
!.github/workflows/
!.github/workflows/*.yml

# Agents
!agents/
!agents/*.md

# Commands (slash commands)
!commands/
!commands/*.md

# Skills (semantic discovery)
!skills/
!skills/*/
!skills/*/SKILL.md
!skills/*/*.md
!skills/*/miniircd

# Documentation
!docs/
!docs/*.md
!docs/architecture/
!docs/architecture/*.yaml
!docs/architecture/*.md
!docs/architecture/*/
!docs/architecture/**/*.md
!docs/scripts/
!docs/scripts/*
!docs/hooks-and-ways/
!docs/hooks-and-ways/*.md
!docs/hooks-and-ways/**/
!docs/hooks-and-ways/**/*.md
!docs/images/
!docs/images/*
!docs/research/
!docs/research/*.md
!docs/reference/
!docs/reference/*/
!docs/reference/**/*.md
!docs/reference/**/*.png

# Hooks and ways
!hooks/
!hooks/*.sh
!hooks/pre-commit
!hooks/ways/
!hooks/ways/*.md
!hooks/ways/*.sh
!hooks/ways/frontmatter-schema.yaml
# ways-corpus.jsonl is generated dynamically by `make setup` — not tracked
# It contains per-user embedding vectors and may include project-local ways
# Nested ways: domain/wayname[/subway...]/way.md + macro.sh + bundled tools
!hooks/ways/*/
!hooks/ways/**/
!hooks/ways/**/*.md
!hooks/ways/**/*.sh
!hooks/ways/**/*.yaml.template
!hooks/ways/**/adr-tool
!hooks/ways/**/chart-tool

# Scripts (shared utilities for hooks, macros, skills)
!scripts/
!scripts/ansi-chart.py
!scripts/context-usage.sh
!scripts/doc-graph.sh
!scripts/install.sh
!scripts/project-pulse
!scripts/task-dashboard.py

# Governance traceability (separable)
# CLI tools (root symlinks to implementation scripts)
!governance-report
!ways-stats
!embed-status
!embed-corpus
!lint-ways
!governance/
!governance/README.md
!governance/*.py
!governance/*.sh
!governance/policies/
!governance/policies/*.md
!governance/policies/*/
!governance/policies/**/*.md

# Tools (source, tests, build artifacts)
!tools/
!tools/way-match/
!tools/way-match/*
!tools/way-match/snowball/
!tools/way-match/snowball/*
!tools/way-embed/
!tools/way-embed/*
!tools/way-embed/llama.cpp
!tools/mmaid/
!tools/mmaid/*

# Standalone tools (user-facing CLI utilities)
!tools/
!tools/*

# Models (GGUF weights for embedding inference)
!models/
!models/*

# Built binaries (way-match checked in, way-embed via GitHub Releases)
!bin/
!bin/way-match
bin/way-embed-*

# Tests
!tests/
!tests/*.md
!tests/*/
!tests/**/*.md
!tests/**/*.sh

# Plugin config (not runtime data)
!plugins/
!plugins/config.json
